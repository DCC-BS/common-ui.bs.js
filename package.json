{
    "version": "1.2.3",
    "name": "@dcc-bs/common-ui.bs.js",
    "license": "MIT",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "url": "https://github.com/DCC-BS/common-ui.bs.js"
    },
    "exports": {
        ".": {
            "types": "./dist/types.d.mts",
            "import": "./dist/module.mjs",
            "require": "./dist/module.mjs",
            "style": "./dist/runtime/assets/main.css"
        },
        "./components": {
            "types": "./dist/runtime/components/index.d.ts",
            "import": "./dist/runtime/components/index.js"
        },
        "./composables": {
            "types": "./dist/runtime/composables/index.d.ts",
            "import": "./dist/runtime/composables/index.js"
        },
        "./utils": {
            "types": "./dist/runtime/utils/index.d.ts",
            "import": "./dist/runtime/utils/index.js"
        },
        "./types": {
            "types": "./dist/runtime/types/index.d.ts",
            "import": "./dist/runtime/types/index.js"
        },
        "./styles": "./dist/runtime/assets/main.css",
        "./dist/*": "./dist/*",
        "./runtime/*": "./dist/runtime/*"
    },
    "main": "./dist/module.mjs",
    "types": "./dist/types.d.mts",
    "files": [
        "dist"
    ],
    "scripts": {
        "prepack": "bunx nuxt-module-build build",
        "generate": "nuxi generate",
        "dev": "nuxi dev playground",
        "dev:build": "nuxi build playground",
        "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
        "release": "bun lint && bun test && bun prepack && changelogen --release && git push --follow-tags",
        "lint": "biome format --write",
        "check": "biome check --write"
    },
    "workspaces": [
        "playground"
    ],
    "devDependencies": {
        "@biomejs/biome": "2.4.5",
        "@nuxt/module-builder": "1.0.2",
        "@tailwindcss/vite": "4.2.1",
        "@types/bun": "1.3.10",
        "@types/markdown-it": "^14.1.2",
        "@types/semver": "^7.7.1",
        "@vitejs/plugin-vue": "6.0.4",
        "tailwindcss": "4.2.1",
        "unbuild": "^3.6.1",
        "vite": "7.3.1",
        "vue": "3.5.29",
        "vue-tsc": "3.2.5"
    },
    "peerDependencies": {
        "@nuxt/icon": "^2.2.0",
        "@nuxt/ui": "^4.5.0",
        "motion-v": "^2.0.0",
        "nuxt": "^4.3.0",
        "typescript": "^5.9.0",
        "zod": "^4.3.0"
    },
    "dependencies": {
        "@nuxt/kit": "4.3.1",
        "@nuxtjs/i18n": "10.2.3",
        "gray-matter": "^4.0.3",
        "markdown-it": "14.1.1",
        "semver": "7.7.4",
        "tailwind-merge": "3.5.0",
        "undici": "7.22.0",
        "typescript": "5.9.3"
    }
}
